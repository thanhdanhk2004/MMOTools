        }
      ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "POST", "PUT", "GET", "PATCH", "DELETE" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "  "
  }
}
